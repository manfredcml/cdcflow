{
  "source": {
    "type": "postgres",
    "host": "localhost",
    "port": 5432,
    "user": "cdc_user",
    "password": "cdc_password",
    "database": "demo",
    "slot_name": "cdc_slot_kafka",
    "publication_name": "cdc_pub",
    "tables": ["public.users", "public.orders"]
  },
  "sink": {
    "type": "kafka",
    "brokers": "localhost:9092",
    "topic_prefix": "cdc"
  },
  "offset": {
    "type": "sqlite",
    "path": "/tmp/cdc-offsets.db",
    "key": "pg-kafka"
  }
}
